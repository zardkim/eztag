# ── eztag 환경 설정 ──────────────────────────────────────────
# 이 파일을 복사하여 .env 로 저장하고 값을 수정하세요.
# cp .env.example .env

# [필수] JWT 서명용 시크릿 키 (32자 이상 랜덤 문자열 권장)
# 생성 예시: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this

# [필수] 음악 라이브러리 폴더 경로 (시놀로지 예시)
MUSIC_PATH=/volume1/music

# PostgreSQL 비밀번호 (기본값: eztag_password)
DB_PASSWORD=eztag_password

# 포트 설정 (기본값 사용 시 생략 가능)
FRONTEND_PORT=5850
BACKEND_PORT=18011

# 로그 레벨: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
