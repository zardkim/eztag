# ============================================================
# eztag 환경 설정 파일
# 사용법: 이 파일을 .env 로 복사 후 값을 수정하세요.
#   cp env.sample .env
# ============================================================

# ── 필수 설정 ─────────────────────────────────────────────

# JWT 인증 시크릿 키 (반드시 변경 — 32자 이상 랜덤 문자열)
# 생성 방법: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-32-char-string

# 음악 폴더 경로
#   기본값: ./data/library (eztag 프로젝트 폴더 내 하위 경로)
#   시놀로지: NAS의 실제 음악 폴더 절대 경로로 변경
#     예) MUSIC_PATH=/volume1/music
#         MUSIC_PATH=/volume2/Media/Music
MUSIC_PATH=./data/library

# ── 데이터베이스 ───────────────────────────────────────────

# PostgreSQL 비밀번호
DB_PASSWORD=eztag_password

# ── 포트 설정 ──────────────────────────────────────────────

# 프론트엔드 접속 포트 (웹 UI)
FRONTEND_PORT=5850

# 백엔드 API 포트
BACKEND_PORT=18011

# ── 이미지 버전 ────────────────────────────────────────────

# Docker 이미지 태그 (latest 또는 특정 버전: 0.4.0)
VERSION=latest

# ── 로그 ──────────────────────────────────────────────────

# 로그 레벨: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
